# 飘悠番茄 Web — Nginx 配置样例
#
# 用法：
#   1. 把 dist/ 目录上传到服务器，例如 /var/www/floattomato/
#   2. 复制本文件到 /etc/nginx/conf.d/floattomato.conf（按你 Nginx 安装位置调整）
#   3. 替换占位 server_name 与 root 路径
#   4. nginx -t && systemctl reload nginx
#
# HTTPS / 域名 / 证书：交给云服务商或宝塔/1Panel 等面板，本文件只关心应用层
#
# 关键设计：
#   - SPA fallback：所有未匹配文件的请求回退到 index.html，由 React Router 接管
#   - PWA 缓存策略：index.html + sw.js + manifest 永不缓存（保证更新立即生效）
#     带 hash 的静态资源（/assets/*.js .css）immutable 长缓存（vite 出包带 hash）
#   - gzip：开启对 JS/CSS/SVG/JSON 的压缩；图片格式已自带压缩不重复压

server {
    listen 80;
    server_name floattomato.example.com;  # ← 改成你的域名

    # 静态文件根目录（dist/ 内容）
    root /var/www/floattomato;
    index index.html;

    # 字符集
    charset utf-8;

    # gzip 压缩 —— 文本资源体积砍 70%+
    gzip on;
    gzip_vary on;
    gzip_comp_level 6;
    gzip_min_length 1024;
    gzip_types
        application/javascript
        application/json
        application/manifest+json
        application/xml
        text/css
        text/plain
        text/xml
        image/svg+xml;

    # ───────────────────────────────────────────
    # PWA 关键文件 —— 永不缓存（保证版本更新立即生效）
    # ───────────────────────────────────────────
    location = /index.html {
        add_header Cache-Control "no-cache, no-store, must-revalidate" always;
        add_header Pragma "no-cache" always;
        expires 0;
    }

    location = /sw.js {
        add_header Cache-Control "no-cache, no-store, must-revalidate" always;
        expires 0;
    }

    location = /manifest.webmanifest {
        add_header Cache-Control "no-cache" always;
        # PWA manifest 标准 MIME
        types { } default_type application/manifest+json;
    }

    location = /workbox-*.js {
        add_header Cache-Control "no-cache, no-store, must-revalidate" always;
        expires 0;
    }

    # ───────────────────────────────────────────
    # 带 hash 的静态资源 —— 1 年 immutable 长缓存
    # vite 出包文件名带 8 位 hash（如 index-CgFSon1P.js），改了内容文件名就变
    # ───────────────────────────────────────────
    location /assets/ {
        add_header Cache-Control "public, max-age=31536000, immutable" always;
        expires 1y;
        access_log off;
    }

    # ───────────────────────────────────────────
    # 图标 / favicon —— 中等缓存（30 天）
    # ───────────────────────────────────────────
    location ~* \.(ico|png|svg|webp|jpg|jpeg|gif|woff2?)$ {
        add_header Cache-Control "public, max-age=2592000" always;
        expires 30d;
        access_log off;
    }

    # ───────────────────────────────────────────
    # SPA fallback —— 路由全部由 React Router 接管
    # ───────────────────────────────────────────
    location / {
        try_files $uri $uri/ /index.html;
    }

    # ───────────────────────────────────────────
    # 安全 header（最小集，可按需扩）
    # ───────────────────────────────────────────
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # 隐藏 nginx 版本号
    server_tokens off;
}
